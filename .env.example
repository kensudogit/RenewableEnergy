# Database
DATABASE_URL=postgresql://re_user:re_password@localhost:5434/re_db

# OpenAI (Railway Variables にも同名で設定)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=
INTERNAL_API_URL=http://localhost:8020
PORT=8020

# Forecast defaults
DEFAULT_REGION=tokyo
DEFAULT_HORIZON_HOURS=48

# Auto trading (paper default; live sandbox on by default)
AUTOTRADE_ENABLED=false
TRADING_DEFAULT_MODE=paper
LIVE_SANDBOX_ENABLED=true
BROKER_API_URL=
BROKER_API_KEY=sandbox-key
BROKER_ACCOUNT_ID=sandbox
# External real gateway only:
# LIVE_TRADING_CONFIRM=I_UNDERSTAND_LIVE_RISK
LIVE_TRADING_CONFIRM=
